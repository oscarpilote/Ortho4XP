name: Recompile Triangle4XP.exe with MinGW-GCC

on: [push]

permissions:
  contents: write
  actions: read

jobs:
  build:
    runs-on: windows-latest

    steps:
    - name: Checkout code
      uses: actions/checkout@v4

    - name: Set up Mingw64
      run: echo "C:\tools\mingw64\bin" >> $env:GITHUB_PATH
      shell: pwsh
    
    - name: Compile C code
      run: |         
         gcc Utils/src/Triangle4XP.c -o Utils/win/Triangle4XP.exe -lm   
    
    - name: Create branch and commit changes
      run: |
         git config --global user.name 'github-actions[bot]'
         git config --global user.email 'github-actions[bot]@users.noreply.github.com'
         git checkout ${{ github.ref_name }}
         git add .
         git commit -m 'Recompile Triangle4XP.exe with MinGW-GCC'

    - name: Push changes
      run: git push origin ${{ github.ref_name }}
